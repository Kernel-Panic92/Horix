# Horix - Variables de entorno
# Copia este archivo como .env y configura los valores

# Puerto del servidor
PORT=3000

# Clave AES para cifrar SMTP password (genera con: openssl rand -hex 32)
HE_SECRET=

# Email y contraseña del admin por defecto (solo se usa si no hay usuarios)
ADMIN_EMAIL=admin@tuempresa.com
ADMIN_PASS=Admin*2026!

# Ruta de la base de datos (opcional)
# DB_PATH=horas_extra.db